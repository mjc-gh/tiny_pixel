<% if @stats.any? %>
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-border">
      <thead class="bg-surface">
        <tr>
          <% if @display_hostname %>
            <th class="px-4 py-3 text-left text-xs font-medium text-content-secondary uppercase tracking-wider">Hostname</th>
          <% end %>
          <th class="px-4 py-3 text-left text-xs font-medium text-content-secondary uppercase tracking-wider">Pathname</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-content-secondary uppercase tracking-wider">Page Views</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-content-secondary uppercase tracking-wider">Unique Page Views</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-content-secondary uppercase tracking-wider">Visits</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-content-secondary uppercase tracking-wider">Sessions</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-content-secondary uppercase tracking-wider">Bounce Rate</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-content-secondary uppercase tracking-wider">Avg Duration</th>
        </tr>
      </thead>
      <tbody class="bg-background divide-y divide-border">
        <% @stats.each do |stat| %>
          <tr class="cursor-pointer hover:bg-surface-hover transition-colors" data-action="click->pathname-filter#selectPathname" data-pathname="<%= stat.pathname %>" data-hostname="<%= stat.hostname %>">
            <% if @display_hostname %>
              <td class="px-4 py-3 text-sm text-content-primary"><%= stat.hostname %></td>
            <% end %>
            <td class="px-4 py-3 text-sm text-content-primary font-medium"><%= stat.pathname %></td>
            <td class="px-4 py-3 whitespace-nowrap text-sm text-content-primary"><%= format_value(stat, :pageviews) %></td>
            <td class="px-4 py-3 whitespace-nowrap text-sm text-content-primary"><%= format_value(stat, :unique_pageviews) %></td>
            <td class="px-4 py-3 whitespace-nowrap text-sm text-content-primary"><%= format_value(stat, :visits) %></td>
            <td class="px-4 py-3 whitespace-nowrap text-sm text-content-primary"><%= format_value(stat, :sessions) %></td>
            <td class="px-4 py-3 whitespace-nowrap text-sm text-content-primary"><%= format_value(stat, :bounce_rate) %></td>
            <td class="px-4 py-3 whitespace-nowrap text-sm text-content-primary"><%= format_value(stat, :avg_duration) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <% if render_pagination? %>
    <%= render PaginationComponent.new(collection: @stats, base_path: @base_path, frame_id: @frame_id, params: @params) %>
  <% end %>
<% else %>
  <p class="text-content-muted py-4">No data available for this period.</p>
<% end %>
