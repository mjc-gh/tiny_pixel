<div class="flex items-center gap-2">
  <label for="interval" class="text-sm font-medium text-content-secondary">Interval:</label>
  <select 
    id="interval" 
    name="interval" 
    class="block w-32 rounded-md border border-border bg-surface px-3 py-2 text-sm text-content-primary focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
    onchange="window.location.href = this.value"
  >
    <% intervals.each do |interval| %>
      <% if selected?(interval[:value]) %>
        <option value="<%= interval_path(interval[:value]) %>" selected>
          <%= interval[:label] %>
        </option>
      <% else %>
        <option value="<%= interval_path(interval[:value]) %>">
          <%= interval[:label] %>
        </option>
      <% end %>
    <% end %>
  </select>
</div>
