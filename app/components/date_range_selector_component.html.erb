<div class="flex items-center gap-2">
  <input type="date" 
         name="start_date"
         value="<%= start_date_value %>"
         class="block rounded-md border border-border bg-surface px-3 py-2 text-sm text-content-primary focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
         data-pathname-filter-target="startDate"
         data-action="change->pathname-filter#updateDateRange">
  <span class="text-sm text-content-secondary">to</span>
  <input type="date" 
         name="end_date"
         value="<%= end_date_value %>"
         class="block rounded-md border border-border bg-surface px-3 py-2 text-sm text-content-primary focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
         data-pathname-filter-target="endDate"
         data-action="change->pathname-filter#updateDateRange">
</div>
