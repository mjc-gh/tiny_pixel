<div data-controller="slideover" data-slideover-open-value="true">
  <dialog data-slideover-target="dialog" class="slideover h-full max-h-full m-0 w-96 p-8 bg-surface backdrop:bg-black/80">
    <!-- Header with close button -->
    <div class="flex justify-between items-center mb-6">
      <h2 class="text-lg font-bold text-text-primary"><%= t("sites.instructions.title") %></h2>
      <button type="button" data-action="slideover#close" class="text-text-secondary hover:text-text-primary transition-colors p-1" aria-label="Close">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Description -->
    <p class="text-text-secondary mb-6"><%= t("sites.instructions.description") %></p>

    <!-- Tracking snippet section -->
    <div class="mb-6" data-controller="clipboard">
      <label class="block text-sm font-medium text-text-primary mb-2"><%= t("sites.instructions.snippet_label") %></label>
      <div class="bg-surface-hover border border-border rounded p-4 mb-3 font-mono text-sm overflow-x-auto" data-clipboard-target="source">
        <%= tracking_snippet %>
      </div>
      <button type="button" 
              data-action="clipboard#copy"
              data-clipboard-target="button"
              class="px-4 py-2 bg-primary text-white rounded hover:bg-primary-dark transition-colors text-sm">
        <%= t("sites.instructions.copy") %>
      </button>
    </div>

    <!-- Close button -->
    <div class="flex justify-end gap-3">
      <button autofocus type="button" 
              data-action="slideover#close"
              class="px-4 py-2 text-text-secondary hover:text-text-primary transition-colors">
        <%= t("sites.instructions.close") %>
      </button>
    </div>
  </dialog>
</div>
