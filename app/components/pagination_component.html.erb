<nav class="flex items-center justify-between border-t border-border pt-4 mt-4" aria-label="Pagination">
  <div class="flex flex-1 justify-between sm:hidden">
    <% if previous_page %>
      <%= link_to "Previous", page_path(previous_page), class: "relative inline-flex items-center rounded-md border border-border bg-surface px-4 py-2 text-sm font-medium text-content-primary hover:bg-surface-hover", **turbo_attributes %>
    <% else %>
      <span class="relative inline-flex items-center rounded-md border border-border bg-surface px-4 py-2 text-sm font-medium text-content-muted cursor-not-allowed">Previous</span>
    <% end %>
    <% if next_page %>
      <%= link_to "Next", page_path(next_page), class: "relative ml-3 inline-flex items-center rounded-md border border-border bg-surface px-4 py-2 text-sm font-medium text-content-primary hover:bg-surface-hover", **turbo_attributes %>
    <% else %>
      <span class="relative ml-3 inline-flex items-center rounded-md border border-border bg-surface px-4 py-2 text-sm font-medium text-content-muted cursor-not-allowed">Next</span>
    <% end %>
  </div>
  <div class="hidden sm:flex sm:flex-1 sm:items-center sm:justify-between">
    <div>
      <p class="text-sm text-content-secondary">
        Page <span class="font-medium text-content-primary"><%= current_page %></span> of <span class="font-medium text-content-primary"><%= total_pages %></span>
      </p>
    </div>
    <div>
      <nav class="isolate inline-flex -space-x-px rounded-md shadow-sm" aria-label="Pagination">
        <% if previous_page %>
          <%= link_to page_path(previous_page), class: "relative inline-flex items-center rounded-l-md px-2 py-2 text-content-secondary ring-1 ring-inset ring-border hover:bg-surface-hover focus:z-20 focus:outline-offset-0", **turbo_attributes do %>
            <span class="sr-only">Previous</span>
            <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M11.78 5.22a.75.75 0 0 1 0 1.06L8.06 10l3.72 3.72a.75.75 0 1 1-1.06 1.06l-4.25-4.25a.75.75 0 0 1 0-1.06l4.25-4.25a.75.75 0 0 1 1.06 0Z" clip-rule="evenodd" />
            </svg>
          <% end %>
        <% else %>
          <span class="relative inline-flex items-center rounded-l-md px-2 py-2 text-content-muted ring-1 ring-inset ring-border cursor-not-allowed">
            <span class="sr-only">Previous</span>
            <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M11.78 5.22a.75.75 0 0 1 0 1.06L8.06 10l3.72 3.72a.75.75 0 1 1-1.06 1.06l-4.25-4.25a.75.75 0 0 1 0-1.06l4.25-4.25a.75.75 0 0 1 1.06 0Z" clip-rule="evenodd" />
            </svg>
          </span>
        <% end %>
        <% page_numbers.each do |page| %>
          <% if page.nil? %>
            <span class="relative inline-flex items-center px-4 py-2 text-sm font-semibold text-content-muted ring-1 ring-inset ring-border">...</span>
          <% elsif page == current_page %>
            <span aria-current="page" class="relative z-10 inline-flex items-center bg-primary px-4 py-2 text-sm font-semibold text-white focus:z-20 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"><%= page %></span>
          <% else %>
            <%= link_to page, page_path(page), class: "relative inline-flex items-center px-4 py-2 text-sm font-semibold text-content-primary ring-1 ring-inset ring-border hover:bg-surface-hover focus:z-20 focus:outline-offset-0", **turbo_attributes %>
          <% end %>
        <% end %>
        <% if next_page %>
          <%= link_to page_path(next_page), class: "relative inline-flex items-center rounded-r-md px-2 py-2 text-content-secondary ring-1 ring-inset ring-border hover:bg-surface-hover focus:z-20 focus:outline-offset-0", **turbo_attributes do %>
            <span class="sr-only">Next</span>
            <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 1 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
            </svg>
          <% end %>
        <% else %>
          <span class="relative inline-flex items-center rounded-r-md px-2 py-2 text-content-muted ring-1 ring-inset ring-border cursor-not-allowed">
            <span class="sr-only">Next</span>
            <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 1 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
            </svg>
          </span>
        <% end %>
      </nav>
    </div>
  </div>
</nav>
