<nav class="fixed top-0 left-0 right-0 bg-surface border-b border-border z-50" data-controller="mobile-menu">
  <div class="container mx-auto px-5">
    <div class="flex justify-between items-center h-16">
      <%= link_to "tiny_pixel", root_path, class: "font-bold text-xl text-content-primary" %>

      <!-- Desktop navigation (hidden on mobile) -->
      <div class="hidden md:flex items-center space-x-6">
        <% if signed_in? %>
          <%= link_to "Sites", sites_path, class: "text-content-secondary hover:text-content-primary" %>
          <%= link_to "Profile", profile_path, class: "text-content-secondary hover:text-content-primary" %>
          <%= link_to "Logout", logout_path, data: { turbo_method: :delete }, class: "text-content-secondary hover:text-content-primary" %>
        <% else %>
          <%= link_to "Login", login_path, class: "text-content-secondary hover:text-content-primary" %>
          <%= link_to "Sign Up", sign_up_path, class: "text-content-secondary hover:text-content-primary" %>
        <% end %>

        <!-- Theme toggle button -->
        <div data-controller="theme">
           <button type="button" class="p-2 rounded-md text-content-secondary hover:text-content-primary hover:bg-surface-hover" data-action="theme#toggle">
             <!-- Sun icon (shown when in dark mode, click to switch to light) -->
             <%= heroicon "sun", type: :outline, data: { "theme-target": "lightIcon" }, class: "hidden h-5 w-5" %>
             <!-- Moon icon (shown when in light mode, click to switch to dark) -->
             <%= heroicon "moon", type: :outline, data: { "theme-target": "darkIcon" }, class: "h-5 w-5" %>
           </button>
        </div>
      </div>

      <!-- Mobile buttons (hamburger + theme toggle) -->
      <div class="flex md:hidden items-center space-x-2">
        <!-- Theme toggle button (mobile) -->
        <div data-controller="theme">
           <button type="button" class="p-2 rounded-md text-content-secondary hover:text-content-primary hover:bg-surface-hover" data-action="theme#toggle">
             <%= heroicon "sun", type: :outline, data: { "theme-target": "lightIcon" }, class: "hidden h-6 w-6" %>
             <%= heroicon "moon", type: :outline, data: { "theme-target": "darkIcon" }, class: "h-6 w-6" %>
           </button>
        </div>

         <!-- Hamburger button -->
         <button type="button" class="p-2 rounded-md text-content-secondary hover:text-content-primary hover:bg-surface-hover" data-action="mobile-menu#toggle">
           <%= heroicon "bars-3", type: :outline, data: { "mobile-menu-target": "openIcon" }, class: "h-6 w-6" %>
           <%= heroicon "x-mark", type: :outline, data: { "mobile-menu-target": "closeIcon" }, class: "hidden h-6 w-6" %>
         </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu (hidden by default) -->
  <div data-mobile-menu-target="menu" class="hidden md:hidden border-t border-border bg-surface">
    <div class="container mx-auto px-5 py-4 space-y-3">
      <% if signed_in? %>
        <%= link_to "Sites", sites_path, class: "block py-2 text-content-secondary hover:text-content-primary", data: { action: "click->mobile-menu#close" } %>
        <%= link_to "Profile", profile_path, class: "block py-2 text-content-secondary hover:text-content-primary", data: { action: "click->mobile-menu#close" } %>
        <%= link_to "Logout", logout_path, data: { turbo_method: :delete, action: "click->mobile-menu#close" }, class: "block py-2 text-content-secondary hover:text-content-primary" %>
      <% else %>
        <%= link_to "Login", login_path, class: "block py-2 text-content-secondary hover:text-content-primary", data: { action: "click->mobile-menu#close" } %>
        <%= link_to "Sign Up", sign_up_path, class: "block py-2 text-content-secondary hover:text-content-primary", data: { action: "click->mobile-menu#close" } %>
      <% end %>
    </div>
  </div>
</nav>
