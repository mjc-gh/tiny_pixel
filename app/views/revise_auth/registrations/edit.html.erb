<div class="w-full max-w-2xl mx-auto space-y-6">
  <h1 class="text-2xl font-bold text-content-primary"><%=t ".profile" %></h1>

  <div class="bg-surface border border-border rounded-lg p-6 sm:p-8">
    <%= form_with model: current_user, url: profile_email_path, class: "space-y-4" do |form| %>
      <fieldset>
        <legend class="text-lg font-semibold text-content-primary mb-4"><%=t ".change_email_address" %></legend>

        <% if current_user.unconfirmed_email? %>
          <div class="bg-warning-bg border border-warning-border rounded-md p-4 mb-4">
            <p class="text-sm text-warning-text"><%=t ".waiting_confirmation", email: current_user.unconfirmed_email %></p>
          </div>
        <% end %>

        <% if form.object.errors.any? %>
          <div class="bg-danger-bg border border-danger-border rounded-md p-4 mb-4">
            <ul class="list-disc list-inside text-sm text-danger-text space-y-1">
              <% form.object.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <p class="text-sm text-content-secondary mb-2"><%=t ".current_email_address", email: current_user.email %></p>
        <p class="text-sm text-content-muted mb-4"><%=t ".confirmation_instructions" %></p>

        <div class="space-y-4">
          <div>
            <%= form.label :unconfirmed_email, t(".new_email"), class: "block text-sm font-medium text-content-label mb-1" %>
            <%= form.email_field :unconfirmed_email, required: true, class: "w-full px-3 py-2 border border-input-border rounded-md bg-input-bg text-content-primary focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" %>
          </div>

          <div>
            <%= form.button t(".save"), class: "bg-primary text-white py-2 px-4 rounded-md hover:bg-primary-hover focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 font-medium" %>
          </div>
        </div>
      </fieldset>
    <% end %>
  </div>

  <div class="bg-surface border border-border rounded-lg p-6 sm:p-8">
    <%= form_with model: current_user, url: profile_password_path, class: "space-y-4" do |form| %>
      <fieldset>
        <legend class="text-lg font-semibold text-content-primary mb-4"><%=t ".change_password" %></legend>

        <% if form.object.errors.any? %>
          <div class="bg-danger-bg border border-danger-border rounded-md p-4 mb-4">
            <ul class="list-disc list-inside text-sm text-danger-text space-y-1">
              <% form.object.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="space-y-4">
          <div data-controller="password-visibility">
            <%= form.label :password_challenge, class: "block text-sm font-medium text-content-label mb-1" %>
            <div class="relative">
              <%= form.password_field :password_challenge, required: true, data: { password_visibility_target: "input" }, class: "w-full px-3 py-2 border border-input-border rounded-md bg-input-bg text-content-primary focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" %>
              <button type="button" data-action="password-visibility#toggle" class="absolute inset-y-0 right-0 pr-3 flex items-center text-content-secondary hover:text-content-primary">
                <!-- eye-slash icon (default, shown when masked) -->
                <svg data-password-visibility-target="hideIcon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.451 10.451 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.522 10.522 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0-4.243-4.243m4.242 4.242L9.88 9.88" />
                </svg>
                <!-- eye icon (hidden, shown when visible) -->
                <svg data-password-visibility-target="showIcon" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                  <circle cx="12" cy="12" r="3" />
                </svg>
              </button>
            </div>
          </div>

          <div data-controller="password-visibility">
            <%= form.label :password, t(".new_password"), class: "block text-sm font-medium text-content-label mb-1" %>
            <div class="relative">
              <%= form.password_field :password, required: true, data: { password_visibility_target: "input" }, class: "w-full px-3 py-2 border border-input-border rounded-md bg-input-bg text-content-primary focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" %>
              <button type="button" data-action="password-visibility#toggle" class="absolute inset-y-0 right-0 pr-3 flex items-center text-content-secondary hover:text-content-primary">
                <!-- eye-slash icon (default, shown when masked) -->
                <svg data-password-visibility-target="hideIcon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0 4.243 4.243m-4.243-4.243L9.586 9.586" />
                </svg>
                <!-- eye icon (hidden, shown when visible) -->
                <svg data-password-visibility-target="showIcon" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                  <circle cx="12" cy="12" r="3" />
                </svg>
              </button>
            </div>
          </div>

          <div data-controller="password-visibility">
            <%= form.label :password_confirmation, class: "block text-sm font-medium text-content-label mb-1" %>
            <div class="relative">
              <%= form.password_field :password_confirmation, required: true, data: { password_visibility_target: "input" }, class: "w-full px-3 py-2 border border-input-border rounded-md bg-input-bg text-content-primary focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" %>
              <button type="button" data-action="password-visibility#toggle" class="absolute inset-y-0 right-0 pr-3 flex items-center text-content-secondary hover:text-content-primary">
                <!-- eye-slash icon (default, shown when masked) -->
                <svg data-password-visibility-target="hideIcon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0 4.243 4.243m-4.243-4.243L9.586 9.586" />
                </svg>
                <!-- eye icon (hidden, shown when visible) -->
                <svg data-password-visibility-target="showIcon" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                  <circle cx="12" cy="12" r="3" />
                </svg>
              </button>
            </div>
          </div>

          <div>
            <%= form.button t(".save"), class: "bg-primary text-white py-2 px-4 rounded-md hover:bg-primary-hover focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 font-medium" %>
          </div>
        </div>
      </fieldset>
    <% end %>
  </div>

  <div class="bg-surface border border-danger-border rounded-lg p-6 sm:p-8">
    <%= form_with url: profile_path, method: :delete do |form| %>
      <fieldset>
        <legend class="text-lg font-semibold text-danger mb-4"><%=t ".delete_account" %></legend>
        <%= form.button t(".delete_account"), data: { turbo_confirm: t(".confirm") }, class: "bg-danger text-white py-2 px-4 rounded-md hover:bg-danger-hover focus:outline-none focus:ring-2 focus:ring-danger focus:ring-offset-2 font-medium" %>
      </fieldset>
    <% end %>
  </div>
</div>
