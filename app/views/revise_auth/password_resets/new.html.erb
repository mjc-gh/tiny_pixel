<div class="w-full max-w-md mx-auto">
  <div class="bg-surface border border-border rounded-lg p-6 sm:p-8">
    <h1 class="text-2xl font-bold text-content-primary mb-6"><%=t ".send_password_reset_instructions" %></h1>

    <%= default_form_with model: @user, url: password_resets_path do |form| %>
      <% if form.object.errors.any? %>
        <div class="bg-danger-bg border border-danger-border rounded-md p-4">
          <ul class="list-disc list-inside text-sm text-danger-text space-y-1">
            <% form.object.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form.email_field :email, required: true, autofocus: true %>

      <div class="pt-2">
        <%= form.button t(".send_password_reset_instructions"), class: "w-full" %>
      </div>
    <% end %>

    <div class="mt-6 pt-6 border-t border-border">
      <%= render "revise_auth/shared/links" %>
    </div>
  </div>
</div>
