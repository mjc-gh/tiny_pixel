<div class="w-full max-w-md mx-auto">
  <div class="bg-surface border border-border rounded-lg p-6 sm:p-8">
    <h1 class="text-2xl font-bold text-text-primary mb-6"><%=t ".log_in" %></h1>

    <%= form_with url: login_path, class: "space-y-4" do |form| %>
      <div>
        <%= form.label :email, class: "block text-sm font-medium text-text-label mb-1" %>
        <%= form.email_field :email, required: true, autofocus: true, class: "w-full px-3 py-2 border border-input-border rounded-md bg-input-bg text-text-primary focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" %>
      </div>

      <div>
        <%= form.label :password, class: "block text-sm font-medium text-text-label mb-1" %>
        <%= form.password_field :password, required: true, class: "w-full px-3 py-2 border border-input-border rounded-md bg-input-bg text-text-primary focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" %>
      </div>

      <div class="pt-2">
        <%= form.button t(".log_in"), class: "w-full bg-primary text-white py-2 px-4 rounded-md hover:bg-primary-hover focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 font-medium" %>
      </div>
    <% end %>

    <div class="mt-6 pt-6 border-t border-border">
      <%= render "revise_auth/shared/links" %>
    </div>
  </div>
</div>
