<% if flash[:alert].present? -%>
  <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 mb-8 rounded relative flex items-start" role="alert" data-controller="alert" data-alert-dismiss-after-value="500000" id="flash-alert">
    <span class="block sm:inline">
      <strong class="font-bold">Error</strong> <%= flash[:alert] -%>
    </span>
    <button data-action="alert#close" class="inline-flex text-red-900 focus:outline-none focus:text-red-800 transition ease-in-out duration-150 ml-auto">
      <%= heroicon 'x-circle', variant: :solid, options: { class: 'w-6 h-6' } -%>
    </button>
  </div>
<% elsif flash[:notice].present? -%>
  <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 mb-8 rounded relative flex items-start" role="alert" data-controller="alert" data-alert-dismiss-after-value="5000" id="flash-notice">
    <span class="block sm:inline"><%= flash[:notice] -%></span>
    <button data-action="alert#close" class="inline-flex text-green-900 focus:outline-none focus:text-green-800 transition ease-in-out duration-150 ml-auto">
      <%= heroicon 'x-circle', variant: :solid, options: { class: 'w-6 h-6' } -%>
    </button>
  </div>
<% end -%>
