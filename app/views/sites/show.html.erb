<div class="space-y-6" data-controller="pathname-filter" data-pathname-filter-site-value="<%= @site.id %>" data-pathname-filter-interval-value="<%= current_interval %>">
  <div>
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div>
        <h1 class="font-bold text-2xl text-text-primary"><%= @site.name %></h1>
        <p class="text-sm text-text-secondary"><%= @site.property_id %></p>
      </div>
       <div class="flex items-center gap-4">
          <%= render IntervalSelectorComponent.new(current_interval: current_interval, site: @site, pathname: current_pathname, hostname: current_hostname) %>
           <%= link_to site_instructions_path(@site), title: t("sites.instructions.title"), data: { turbo_frame: "modals", action: "slideover#open" }, class: "text-text-secondary hover:text-text-primary transition-colors" do %>
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" />
            </svg>
          <% end %>
          <%= link_to edit_site_path(@site), title: t("common.settings"), class: "text-text-secondary hover:text-text-primary transition-colors" do %>
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.343 3.94c.09-.542.56-.94 1.11-.94h1.093c.55 0 1.02.398 1.11.94l.149.894c.07.424.384.764.78.93.398.164.855.142 1.205-.108l.737-.527a1.125 1.125 0 0 1 1.45.12l.773.774c.39.389.44 1.002.12 1.45l-.527.737c-.25.35-.272.806-.107 1.204.165.397.505.71.93.78l.893.15c.543.09.94.559.94 1.109v1.094c0 .55-.397 1.02-.94 1.11l-.894.149c-.424.07-.764.383-.929.78-.165.398-.143.854.107 1.204l.527.738c.32.447.269 1.06-.12 1.45l-.774.773a1.125 1.125 0 0 1-1.449.12l-.738-.527c-.35-.25-.806-.272-1.203-.107-.398.165-.71.505-.781.929l-.149.894c-.09.542-.56.94-1.11.94h-1.094c-.55 0-1.019-.398-1.11-.94l-.148-.894c-.071-.424-.384-.764-.781-.93-.398-.164-.854-.142-1.204.108l-.738.527c-.447.32-1.06.269-1.45-.12l-.773-.774a1.125 1.125 0 0 1-.12-1.45l.527-.737c.25-.35.272-.806.108-1.204-.165-.397-.506-.71-.93-.78l-.894-.15c-.542-.09-.94-.56-.94-1.109v-1.094c0-.55.398-1.02.94-1.11l.894-.149c.424-.07.765-.383.93-.78.165-.398.143-.854-.108-1.204l-.526-.738a1.125 1.125 0 0 1 .12-1.45l.773-.773a1.125 1.125 0 0 1 1.45-.12l.737.527c.35.25.807.272 1.204.107.397-.165.71-.505.78-.929l.15-.894Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
            </svg>
          <% end %>
       </div>
    </div>

    <% if current_pathname.present? || current_hostname.present? %>
      <div class="mt-4 p-3 bg-primary/10 border border-primary/20 rounded-lg flex items-center justify-between" data-pathname-filter-target="filterIndicator">
        <p class="text-sm text-text-primary">
          Filtered by: <span class="font-semibold" data-filter-text><%= "#{current_hostname}#{current_pathname}" %></span>
        </p>
        <button type="button" class="text-xs font-medium text-primary hover:text-primary/80 transition-colors" data-action="click->pathname-filter#clearFilter">
          Clear Filter
        </button>
      </div>
    <% else %>
      <div class="mt-4 p-3 bg-primary/10 border border-primary/20 rounded-lg flex items-center justify-between hidden" data-pathname-filter-target="filterIndicator">
        <p class="text-sm text-text-primary">
          Filtered by: <span class="font-semibold" data-filter-text></span>
        </p>
        <button type="button" class="text-xs font-medium text-primary hover:text-primary/80 transition-colors" data-action="click->pathname-filter#clearFilter">
          Clear Filter
        </button>
      </div>
    <% end %>
  </div>

  <section>
    <div class="border border-border rounded-lg p-4 bg-surface">
      <turbo-frame id="pathname_stats" src="<%= site_pathnames_path(@site, interval: current_interval, pathname: current_pathname, hostname: current_hostname) %>" loading="lazy">
        <p class="text-text-muted">Loading pathname summary...</p>
      </turbo-frame>
    </div>
  </section>

  <div class="gap-y-8 gap-x-4 grid grid-cols-1 md:grid-cols-2">
    <section>
      <div class="border border-border rounded-lg p-4 bg-surface">
        <turbo-frame id="page_views_stats" src="<%= site_page_views_path(@site, interval: current_interval, pathname: current_pathname, hostname: current_hostname) %>" loading="lazy" data-pathname-filter-target="pageViewsFrame">
          <p class="text-text-muted">Loading page views...</p>
        </turbo-frame>
      </div>
    </section>

    <section>
      <div class="border border-border rounded-lg p-4 bg-surface">
        <turbo-frame id="visitors_stats" src="<%= site_visitors_path(@site, interval: current_interval, pathname: current_pathname, hostname: current_hostname) %>" loading="lazy" data-pathname-filter-target="visitorsFrame">
          <p class="text-text-muted">Loading visitors...</p>
        </turbo-frame>
      </div>
    </section>

    <section>
      <div class="border border-border rounded-lg p-4 bg-surface">
        <turbo-frame id="avg_duration_stats" src="<%= site_avg_duration_index_path(@site, interval: current_interval, pathname: current_pathname, hostname: current_hostname) %>" loading="lazy" data-pathname-filter-target="avgDurationFrame">
          <p class="text-text-muted">Loading avg duration...</p>
        </turbo-frame>
      </div>
    </section>

    <section>
      <div class="border border-border rounded-lg p-4 bg-surface">
        <turbo-frame id="bounce_rate_stats" src="<%= site_bounce_rate_index_path(@site, interval: current_interval, pathname: current_pathname, hostname: current_hostname) %>" loading="lazy" data-pathname-filter-target="bounceRateFrame">
          <p class="text-text-muted">Loading bounce rate...</p>
        </turbo-frame>
      </div>
    </section>
  </div>
</div>
