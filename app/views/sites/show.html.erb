<div class="space-y-6" data-controller="site-dashboard" data-site-dashboard-site-value="<%= @site.id %>" data-site-dashboard-interval-value="<%= current_interval %>" data-site-dashboard-pathname-value="<%= current_pathname %>" data-site-dashboard-hostname-value="<%= current_hostname %>" data-site-dashboard-start-date-value="<%= current_start_date&.iso8601 %>" data-site-dashboard-end-date-value="<%= current_end_date&.iso8601 %>" data-site-dashboard-dimension-type-value="<%= current_dimension_type %>" data-site-dashboard-dimension-value-value="<%= current_dimension_value %>">
  <div>
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div class="space-y-1">
        <!-- Site name with settings icon -->
        <div class="flex justify-between sm:justify-start sm:gap-2 items-center">
          <h1 class="font-bold text-2xl text-content-primary"><%= @site.name %></h1>
           <%= link_to edit_site_path(@site), title: t("common.settings"), class: "text-content-secondary hover:text-content-primary transition-colors" do %>
             <%= heroicon "cog-8-tooth", type: :outline, class: "h-5 w-5" %>
           <% end %>
        </div>
        <!-- Property ID with instructions icon -->
        <div class="flex justify-between sm:justify-start sm:gap-2 items-center">
          <p class="text-sm text-content-secondary"><%= @site.property_id %></p>
           <%= link_to site_instructions_path(@site), title: t("sites.instructions.title"), data: { turbo_frame: "modals", action: "slideover#open" }, class: "text-content-secondary hover:text-content-primary transition-colors" do %>
             <%= heroicon "code-bracket", type: :outline, class: "h-5 w-5" %>
           <% end %>
        </div>
      </div>
      <div class="flex items-center gap-4">
        <%= render IntervalSelectorComponent.new(current_interval: current_interval, site: @site, pathname: current_pathname, hostname: current_hostname, start_date: current_start_date, end_date: current_end_date, dimension_type: current_dimension_type, dimension_value: current_dimension_value) %>
        <%= render DateRangeSelectorComponent.new(start_date: current_start_date, end_date: current_end_date, site: @site) %>
      </div>
    </div>

    <div class="mt-4 flex flex-wrap gap-2">
      <% if current_pathname.present? || current_hostname.present? %>
        <div class="p-3 bg-primary/10 border border-primary/20 rounded-lg flex items-center justify-between gap-3">
          <p class="text-sm text-content-primary">
            Path: <span class="font-semibold" data-filter-text-pathname><%= "#{current_hostname}#{current_pathname}" %></span>
          </p>
          <button type="button" class="text-xs font-medium text-primary hover:text-primary/80 transition-colors" data-action="click->site-dashboard#clearPathnameFilter">
            ✕
          </button>
        </div>
      <% end %>

      <% if current_dimension_type.present? %>
        <div class="p-3 bg-primary/10 border border-primary/20 rounded-lg flex items-center justify-between gap-3">
          <p class="text-sm text-content-primary">
            <%= current_dimension_type.humanize %>: <span class="font-semibold" data-filter-text-dimension><%= format_dimension_value(current_dimension_type, current_dimension_value) %></span>
          </p>
          <button type="button" class="text-xs font-medium text-primary hover:text-primary/80 transition-colors" data-action="click->site-dashboard#clearDimensionFilter">
            ✕
          </button>
        </div>
      <% end %>
    </div>
  </div>

  <section>
    <div class="border border-border rounded-lg p-4 bg-surface">
      <turbo-frame id="pathname_stats" src="<%= site_pathnames_path(@site, interval: current_interval, pathname: current_pathname, hostname: current_hostname, start_date: current_start_date&.iso8601, end_date: current_end_date&.iso8601, dimension_type: current_dimension_type, dimension_value: current_dimension_value) %>" loading="lazy">
        <p class="text-content-muted">Loading pathname summary...</p>
      </turbo-frame>
    </div>
  </section>

  <div class="gap-y-8 gap-x-4 grid grid-cols-1 md:grid-cols-2">
    <section>
      <div class="border border-border rounded-lg p-4 bg-surface">
         <turbo-frame id="page_views_stats" src="<%= site_page_views_path(@site, interval: current_interval, pathname: current_pathname, hostname: current_hostname, start_date: current_start_date&.iso8601, end_date: current_end_date&.iso8601, dimension_type: current_dimension_type, dimension_value: current_dimension_value) %>" loading="lazy">
          <p class="text-content-muted">Loading page views...</p>
        </turbo-frame>
      </div>
    </section>

    <section>
      <div class="border border-border rounded-lg p-4 bg-surface">
         <turbo-frame id="visitors_stats" src="<%= site_visitors_path(@site, interval: current_interval, pathname: current_pathname, hostname: current_hostname, start_date: current_start_date&.iso8601, end_date: current_end_date&.iso8601, dimension_type: current_dimension_type, dimension_value: current_dimension_value) %>" loading="lazy">
          <p class="text-content-muted">Loading visitors...</p>
        </turbo-frame>
      </div>
    </section>

    <section>
      <div class="border border-border rounded-lg p-4 bg-surface">
         <turbo-frame id="avg_duration_stats" src="<%= site_avg_duration_index_path(@site, interval: current_interval, pathname: current_pathname, hostname: current_hostname, start_date: current_start_date&.iso8601, end_date: current_end_date&.iso8601, dimension_type: current_dimension_type, dimension_value: current_dimension_value) %>" loading="lazy">
          <p class="text-content-muted">Loading avg duration...</p>
        </turbo-frame>
      </div>
    </section>

     <section>
      <div class="border border-border rounded-lg p-4 bg-surface">
         <turbo-frame id="bounce_rate_stats" src="<%= site_bounce_rate_index_path(@site, interval: current_interval, pathname: current_pathname, hostname: current_hostname, start_date: current_start_date&.iso8601, end_date: current_end_date&.iso8601, dimension_type: current_dimension_type, dimension_value: current_dimension_value) %>" loading="lazy">
          <p class="text-content-muted">Loading bounce rate...</p>
        </turbo-frame>
      </div>
    </section>
  </div>

  <div class="gap-y-8 gap-x-4 grid grid-cols-1 md:grid-cols-2 mt-8">
    <section>
      <div class="border border-border rounded-lg p-4 bg-surface">
         <turbo-frame id="country_stats" src="<%= site_dimensions_path(@site, type: 'country', interval: current_interval, pathname: current_pathname, hostname: current_hostname, start_date: current_start_date&.iso8601, end_date: current_end_date&.iso8601, dimension_type: current_dimension_type, dimension_value: current_dimension_value) %>" loading="lazy">
          <p class="text-content-muted">Loading countries...</p>
        </turbo-frame>
      </div>
    </section>

    <section>
      <div class="border border-border rounded-lg p-4 bg-surface">
         <turbo-frame id="browser_stats" src="<%= site_dimensions_path(@site, type: 'browser', interval: current_interval, pathname: current_pathname, hostname: current_hostname, start_date: current_start_date&.iso8601, end_date: current_end_date&.iso8601, dimension_type: current_dimension_type, dimension_value: current_dimension_value) %>" loading="lazy">
          <p class="text-content-muted">Loading browsers...</p>
        </turbo-frame>
      </div>
    </section>

    <section>
      <div class="border border-border rounded-lg p-4 bg-surface">
         <turbo-frame id="device_type_stats" src="<%= site_dimensions_path(@site, type: 'device_type', interval: current_interval, pathname: current_pathname, hostname: current_hostname, start_date: current_start_date&.iso8601, end_date: current_end_date&.iso8601, dimension_type: current_dimension_type, dimension_value: current_dimension_value) %>" loading="lazy">
          <p class="text-content-muted">Loading device types...</p>
        </turbo-frame>
      </div>
    </section>

    <section>
      <div class="border border-border rounded-lg p-4 bg-surface">
         <turbo-frame id="referrer_hostname_stats" src="<%= site_dimensions_path(@site, type: 'referrer_hostname', interval: current_interval, pathname: current_pathname, hostname: current_hostname, start_date: current_start_date&.iso8601, end_date: current_end_date&.iso8601, dimension_type: current_dimension_type, dimension_value: current_dimension_value) %>" loading="lazy">
          <p class="text-content-muted">Loading referrers...</p>
        </turbo-frame>
      </div>
    </section>
  </div>
</div>
