<turbo-frame id="page_views_stats">
  <% if current_view_mode == "graph" %>
    <%= render StatsChartComponent.new(data: @chart_data, time_column: stats_time_column, chart_id: "page_views_chart") %>
  <% else %>
    <%= render StatsTableComponent.new(
      stats: @stats,
      columns: [
        { label: "Page Views", method: :pageviews },
        { label: "Unique Page Views", method: :unique_pageviews }
      ],
      time_column: stats_time_column,
      pagination: @stats,
      frame_id: "page_views_stats",
      base_path: site_page_views_path(@site),
      params: { interval: current_interval, view_mode: current_view_mode }
    ) %>
  <% end %>
</turbo-frame>
