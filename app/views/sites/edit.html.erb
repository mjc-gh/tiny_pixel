<div class="w-full max-w-2xl mx-auto space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-content-primary"><%= t("sites.edit.title") %></h1>
    <%= link_to "← " + t("common.back"), site_path(@site), class: "text-sm text-primary hover:text-primary/80 transition-colors" %>
  </div>

  <div class="bg-surface border border-border rounded-lg p-6 sm:p-8">
    <%= default_form_with model: @site, local: true do |form| %>
      <% if @site.errors.any? %>
        <div class="bg-danger-bg border border-danger-border rounded-md p-4 mb-4">
          <ul class="list-disc list-inside text-sm text-danger-text space-y-1">
            <% @site.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <fieldset>
        <legend class="text-lg font-semibold text-content-primary mb-4"><%= t("sites.edit.settings") %></legend>

        <div class="space-y-4">
          <div>
            <%= form.text_field :name, label: t("sites.edit.name_label") %>
            <p class="text-xs text-content-muted mt-1"><%= t("sites.edit.name_help") %></p>
          </div>

          <div>
            <%= form.select :salt_duration, Site.salt_durations.keys.map { |key| [t("sites.salt_durations.#{key}"), key] }, {}, label: t("sites.edit.salt_duration_label") %>
            <p class="text-xs text-content-muted mt-1"><%= t("sites.edit.salt_duration_help") %></p>
          </div>

          <div>
            <label class="flex items-center gap-3 cursor-pointer">
              <%= form.check_box :display_hostname %>
              <span class="text-sm font-medium text-content-label"><%= t("sites.edit.display_hostname_label") %></span>
            </label>
            <p class="text-xs text-content-muted mt-1"><%= t("sites.edit.display_hostname_help") %></p>
          </div>

          <div>
            <%= form.button t("common.save") %>
          </div>
        </div>
      </fieldset>
    <% end %>
  </div>
</div>
