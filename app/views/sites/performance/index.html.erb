<turbo-frame id="performance_stats">
  <div class="space-y-6">
    <div>
      <h3 class="text-sm font-medium text-text-secondary mb-2">Average Duration</h3>
      <%= render StatsChartComponent.new(data: @avg_duration_chart_data, time_column: stats_time_column, chart_id: "avg_duration_chart") %>
    </div>
    <div>
      <h3 class="text-sm font-medium text-text-secondary mb-2">Bounce Rate</h3>
      <%= render StatsChartComponent.new(data: @bounce_rate_chart_data, time_column: stats_time_column, chart_id: "bounce_rate_chart") %>
    </div>
  </div>
</turbo-frame>
