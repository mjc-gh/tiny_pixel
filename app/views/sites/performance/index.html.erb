<turbo-frame id="performance_stats">
  <% if current_view_mode == "graph" %>
    <%= render StatsChartComponent.new(data: @chart_data, time_column: stats_time_column, chart_id: "performance_chart") %>
  <% else %>
    <%= render StatsTableComponent.new(
      stats: @stats,
      columns: [
        { label: "Avg Duration", method: :avg_duration },
        { label: "Bounce Rate", method: :bounce_rate }
      ],
      time_column: stats_time_column,
      pagination: @stats,
      frame_id: "performance_stats",
      base_path: site_performance_index_path(@site),
      params: { interval: current_interval, view_mode: current_view_mode }
    ) %>
  <% end %>
</turbo-frame>
